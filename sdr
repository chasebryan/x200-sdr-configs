#!/usr/bin/env bash

set -euo pipefail

ROOT="${HOME}/rtl-sdr-setup"
SCAN_DIR="${ROOT}/scans"
mkdir -p "$SCAN_DIR"

latest_scan_report() {
  ls -1t "$SCAN_DIR"/scan-*.txt 2>/dev/null | head -n 1
}

gqrx_config_dir() {
  if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
    printf '%s/gqrx
' "$XDG_CONFIG_HOME"
  else
    printf '%s/.config/gqrx
' "$HOME"
  fi
}

gqrx_config_path() {
  local name="${1:?}"
  printf '%s/%s
' "$(gqrx_config_dir)" "$name"
}

import_scan_to_bookmarks() {
  local scan_file="$1"
  local output_file="$2"
  python3 - "$scan_file" "$output_file" <<'PY_INNER'
import re
import sys
from pathlib import Path

scan_file = Path(sys.argv[1])
output_file = Path(sys.argv[2])

bands = {
    'FM broadcast': ('WFM', 150000, 'Broadcast FM'),
    'Airband': ('AM', 8000, 'Airband'),
    'Weather / satellite': ('WFM', 25000, 'Weather'),
    '2m amateur': ('NFM', 12500, 'Amateur'),
    'VHF high': ('NFM', 12500, 'VHF'),
    'UHF public safety': ('NFM', 12500, 'UHF'),
    '700/800 MHz': ('NFM', 12500, '700MHz'),
}

lines = scan_file.read_text().splitlines()
bookmarks = []
current_band = None
for line in lines:
    line = line.strip()
    if not line:
        continue
    if line.startswith('# '):
        current_band = line[2:].split(' | ')[0]
        continue
    m = re.match(r'^([0-9]+\.[0-9]+) MHz\s+(-?[0-9]+\.?[0-9]*) dBm\s+(.*)$', line)
    if not m:
        continue
    freq_hz = int(round(float(m.group(1)) * 1_000_000))
    band = current_band or 'Survey'
    modulation, bandwidth, tag = bands.get(band, ('NFM', 12500, 'Survey'))
    name = f'{band} signal @ {float(m.group(1)):.6f} MHz'
    bookmarks.append((freq_hz, name, modulation, bandwidth, tag))

with output_file.open('w', encoding='utf-8') as fh:
    fh.write('# Tag name; color\n')
    fh.write('Survey; #a0a0a0\n')
    fh.write('Broadcast FM; #4c8bf5\n')
    fh.write('Airband; #f4b400\n')
    fh.write('Weather; #0f9d58\n')
    fh.write('Amateur; #ab47bc\n')
    fh.write('VHF; #26a69a\n')
    fh.write('UHF; #ef5350\n')
    fh.write('700MHz; #5c6bc0\n')
    fh.write('\n')
    fh.write('# Frequency; Name; Modulation; Bandwidth; Tags\n')
    for freq_hz, name, modulation, bandwidth, tag in bookmarks:
        fh.write(f'{freq_hz}; {name}; {modulation}; {bandwidth}; {tag}\n')
PY_INNER
}

usage() {
  cat <<'EOF_USAGE'
Usage:
  sdr test
  sdr fm [frequency]
  sdr gui
  sdr scan [seconds-per-band]
  sdr import-scan [scan-report]

Defaults:
  frequency = 100e6
  seconds-per-band = 8

Examples:
  sdr test
  sdr fm
  sdr fm 101.1e6
  sdr weather
  sdr sarnet
  sdr gui
  sdr scan
  sdr scan 12
  sdr import-scan
EOF_USAGE
}

scan_band() {
  local range="$1"
  local label="$2"
  local mode_hint="$3"
  local dwell="$4"
  local tmp_csv
  tmp_csv=$(mktemp)
  trap 'rm -f "$tmp_csv"' RETURN

  rtl_power -f "$range" -i 1 -e "${dwell}s" -g 0 -P > "$tmp_csv"

  awk -v band_label="$label" -v mode_hint="$mode_hint" '
    NR == 1 { next }
    {
      low = $3 + 0
      high = $4 + 0
      step = $5 + 0
      if (!seen) {
        bins = int((high - low) / step + 0.5) + 1
        for (i = 1; i <= bins; i++) {
          freq[i] = low + (i - 1) * step
        }
        seen = 1
      }
      for (i = 8; i <= NF; i++) {
        idx = i - 7
        val = $i + 0
        if (!(idx in peak) || val > peak[idx]) {
          peak[idx] = val
        }
      }
    }
    END {
      if (!seen) {
        print "# " band_label " | " mode_hint " | no data"
        exit
      }

      sum = 0
      count = 0
      for (i = 1; i <= bins; i++) {
        if (i in peak) {
          sum += peak[i]
          count++
        }
      }

      floor = (count > 0) ? sum / count : -999
      thresh = floor + 8
      printf "# %s | %s | floor %.1f dBm | threshold %.1f dBm\n", band_label, mode_hint, floor, thresh

      found = 0
      best_idx = 1
      best_val = -9999
      for (i = 1; i <= bins; i++) {
        if (!(i in peak)) {
          continue
        }
        if (peak[i] > best_val) {
          best_val = peak[i]
          best_idx = i
        }
        left_ok = (i == 1) || !(i - 1 in peak) || peak[i] >= peak[i - 1]
        right_ok = (i == bins) || !(i + 1 in peak) || peak[i] >= peak[i + 1]
        if (peak[i] >= thresh && left_ok && right_ok) {
          printf "%10.6f MHz  %6.1f dBm  %s\n", freq[i] / 1000000.0, peak[i], mode_hint
          found = 1
        }
      }

      if (!found && best_idx in peak) {
        printf "%10.6f MHz  %6.1f dBm  %s (strongest bin)\n", freq[best_idx] / 1000000.0, best_val, mode_hint
      }
    }
  ' "$tmp_csv"

  rm -f "$tmp_csv"
  trap - RETURN
}

case "${1:-}" in
  "")
    usage
    exit 1
    ;;
  test)
    shift || true
    if [[ $# -eq 0 ]]; then
      rc=0
      timeout 5s rtl_test || rc=$?
      if [[ $rc -eq 124 ]]; then
        exit 0
      fi
      exit $rc
    fi
    exec rtl_test "$@"
    ;;
  fm|listen)
    shift || true
    freq="${1:-100e6}"
    shift || true
    exec rtl_fm -f "$freq" -M wbfm -s 200k -r 48k "$@" | aplay -q -r 48000 -f S16_LE -c 1
    ;;
  import-scan)
    shift || true
    scan_file="${1:-$(latest_scan_report)}"
    if [[ -z "${scan_file:-}" || ! -f "$scan_file" ]]; then
      printf '%s
' 'No scan report found. Run `sdr scan` first.' >&2
      exit 1
    fi
    output_file="$(gqrx_config_path bookmarks.csv)"
    import_scan_to_bookmarks "$scan_file" "$output_file"
    printf 'Wrote %s from %s
' "$output_file" "$scan_file"
    ;;
  gui)
    shift || true
    exec gqrx -c "$(gqrx_config_path default.conf)" "$@"
    ;;
  weather)
    shift || true
    exec gqrx -c "$(gqrx_config_path noaa.conf)" "$@"
    ;;
  sarnet)
    shift || true
    exec gqrx -c "$(gqrx_config_path sarnet.conf)" "$@"
    ;;
  scan)
    shift || true
    dwell="${1:-8}"
    if pgrep -x gqrx >/dev/null 2>&1 || pgrep -x rtl_test >/dev/null 2>&1 || pgrep -x rtl_fm >/dev/null 2>&1 || pgrep -x rtl_power >/dev/null 2>&1; then
      printf '%s\n' 'Gqrx or another RTL-SDR tool is already running. Close it before starting a scan.' >&2
      exit 2
    fi
    stamp=$(date +%Y%m%d-%H%M%S)
    report="$SCAN_DIR/scan-$stamp.txt"
    {
      printf 'RTL-SDR scan report\n'
      printf 'Generated: %s\n' "$(date -Is)"
      printf 'Device: RTL-SDR Blog V4\n'
      printf 'Pass time per band: %ss\n\n' "$dwell"
      scan_band '24M:88M:1M' 'VHF low' 'Unknown / low-band' "$dwell"
      printf '\n'
      scan_band '88M:108M:200k' 'FM broadcast' 'WFM broadcast' "$dwell"
      printf '\n'
      scan_band '108M:137M:25k' 'Airband' 'AM airband' "$dwell"
      printf '\n'
      scan_band '137M:144M:25k' 'Weather / satellite' 'WFM / NFM' "$dwell"
      printf '\n'
      scan_band '144M:148M:12.5k' '2m amateur' 'NFM amateur' "$dwell"
      printf '\n'
      scan_band '148M:174M:25k' 'VHF high' 'NFM / misc' "$dwell"
      printf '\n'
      scan_band '174M:300M:1M' 'Band III / VHF TV' 'Digital / wideband' "$dwell"
      printf '\n'
      scan_band '300M:380M:1M' 'UHF gap' 'Digital / wideband' "$dwell"
      printf '\n'
      scan_band '380M:470M:25k' 'UHF public safety' 'NFM / DMR / misc' "$dwell"
      printf '\n'
      scan_band '470M:698M:500k' 'UHF TV' 'Wideband / digital' "$dwell"
      printf '\n'
      scan_band '698M:806M:100k' '700/800 MHz' 'Digital / NFM' "$dwell"
      printf '\n'
      scan_band '806M:960M:25k' 'ISM / cellular' 'Digital / NFM' "$dwell"
      printf '\n'
      scan_band '960M:1300M:50k' 'L-band' 'Satellite / ISM' "$dwell"
      printf '\n'
      scan_band '1300M:1766M:500k' 'Upper L / S-band' 'Wideband / digital' "$dwell"
    } | tee "$report"

    if command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$report" >/dev/null 2>&1 &
    fi
    printf '\nReport saved to %s\n' "$report"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    printf 'Unknown command: %s\n\n' "$1" >&2
    usage >&2
    exit 1
    ;;
esac
